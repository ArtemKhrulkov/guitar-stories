PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/guitar_stock
GIN_MODE=debug
ALLOWED_ORIGINS=http://localhost:3000
ADMIN_USER=admin
ADMIN_PASS=changeme

# Scraper Configuration
SCRAPER_MAX_CONCURRENT=3
SCRAPER_RATE_LIMIT=120s
SCRAPER_RETRIES=3
SCRAPER_RETRY_DELAY=10s

# Proxy URLs (comma-separated, with optional auth)
# Format: http://user:pass@host:port or http://host:port
# Leave empty for direct connection
# Example: http://username:password@proxy.smartproxy.net:3120
PROXY_URLS=
